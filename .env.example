# Banner Studio Pro - Environment Variables
# Copy thành .env.local cho development

# ─── YouTube Demo Video ──────────────────────────────────────────────
VITE_YOUTUBE_DEMO_ID=Kc7xo710I2U

# ─── KIE Marketplace API ─────────────────────────────────────────────
# Lấy từ: https://kie.ai/vi/settings > Khóa API
VITE_KIE_API_KEY=your_kie_api_key_here
VITE_KIE_WEBHOOK_HMAC=your_webhook_hmac_here
VITE_KIE_DEFAULT_MODEL=gpt-image-2

# ─── Supabase (Auth) ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://csesonwxvgvkozfbtpvb.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Firebase (Legacy Auth) ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
